{
  "kind": "collectionType",
  "collectionName": "team_members",
  "info": {
    "singularName": "our-team",
    "pluralName": "our-teams",
    "displayName": "Our Team",
    "description": "Team members for Capitol Improvements"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "searchable": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "searchable": true
    },
    "name": {
      "type": "string",
      "required": false
    },
    "jobTitle": {
      "type": "string",
      "required": false
    },
    "role": {
      "type": "enumeration",
      "required": false,
      "enum": [
        "owner",
        "co-owner",
        "head-manager",
        "manager",
        "office-admin",
        "accounting",
        "consultant",
        "installer"
      ],
      "searchable": true
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "location": {
      "type": "enumeration",
      "required": false,
      "enum": [
        "improveitmd",
        "carolina"
      ],
      "searchable": true
    },
    "bio": {
      "type": "text",
      "required": false
    }
  }
}
