{
  "name": "webflow-strapi-migration",
  "version": "1.0.0",
  "description": "Migration scripts for Webflow CMS to Strapi 5",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "export": "tsx scripts/01-export-webflow.ts",
    "generate-schemas": "tsx scripts/02-generate-schemas.ts",
    "import-content": "tsx scripts/03-import-content.ts",
    "upload-assets": "tsx scripts/04-upload-assets.ts",
    "verify": "tsx scripts/05-verify-migration.ts",
    "sync-alt-texts": "tsx scripts/sync-alt-texts.ts",
    "convert-to-blocks": "tsx scripts/convert-html-to-blocks.ts",
    "migrate-db-to-blocks": "tsx scripts/migrate-richtext-to-blocks.ts",
    "import-service-areas": "tsx scripts/import-service-areas.ts",
    "import-videos": "tsx scripts/import-videos.ts",
    "update-coordinates": "tsx scripts/update-service-area-coordinates.ts",
    "link-service-pages": "tsx scripts/link-service-area-pages.ts",
    "generate-faqs": "tsx scripts/generate-faqs-for-cities-v2.ts",
    "process-jobs": "tsx scripts/process-jobs-csv.ts",
    "sync-richtext": "tsx scripts/sync-richtext-fields.ts",
    "sync-all-richtext": "tsx scripts/sync-all-richtext-fields.ts",
    "update-why-choose-us": "tsx scripts/update-why-choose-us.ts",
    "update-areas-we-serve": "tsx scripts/update-areas-we-serve.ts",
    "research-hoa": "tsx scripts/research-hoa-resources.ts",
    "update-community-guidelines": "tsx scripts/update-community-guidelines.ts",
    "fix-crownsville": "tsx scripts/fix-crownsville-to-bowie.ts",
    "regenerate-contact-details": "tsx scripts/regenerate-location-contact-details.ts",
    "simplify-areas-we-serve": "tsx scripts/simplify-areas-we-serve.ts",
    "sync-areas-to-contact-details": "tsx scripts/sync-areas-to-contact-details.ts",
    "enrich-community-guidelines": "tsx scripts/enrich-community-guidelines.ts",
    "push-warranty-tables": "tsx scripts/push-warranty-tables.ts",
    "migrate:all": "npm run export && npm run generate-schemas && npm run import-content && npm run upload-assets && npm run verify"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@types/pg": "^8.16.0",
    "axios": "^1.7.0",
    "csv-parse": "^5.5.0",
    "csv-stringify": "^6.5.0",
    "dotenv": "^16.4.0",
    "form-data": "^4.0.0",
    "openai": "^6.18.0",
    "p-limit": "^6.1.0",
    "pg": "^8.16.3",
    "webflow-api": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
